# NHPMBR web app — copy to `.env.local` and adjust.

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=NHPMBR

# Auth.js v5: In production set AUTH_SECRET (openssl rand -base64 32). For local dev,
# omit AUTH_SECRET / NEXTAUTH_SECRET entirely so auth.ts uses its built-in dev fallback.
AUTH_URL=http://localhost:3000

NEXTAUTH_URL=http://localhost:3000

# Keycloak OIDC (must match infra/docker/keycloak/nhpmbr-realm.json client)
KEYCLOAK_CLIENT_ID=nhpmbr-web
KEYCLOAK_CLIENT_SECRET=dev-only-web-client-secret-change-me
KEYCLOAK_ISSUER=http://localhost:8080/realms/nhpmbr

# --- Vercel (production) — set in Vercel → Environment Variables, not in this file ---
# AUTH_SECRET=<openssl rand -base64 32>
# AUTH_URL=https://your-app.vercel.app
# KEYCLOAK_ISSUER=https://<public-keycloak-host>/realms/nhpmbr
# NEXT_PUBLIC_API_BASE_URL=https://<deployed-fastapi-host>
# See docs/06-deploy-vercel.md
