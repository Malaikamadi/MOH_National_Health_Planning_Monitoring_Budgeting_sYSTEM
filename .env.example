# =========================================================================
# NHPMBR — Local development environment template
#
# Copy this file to `.env` and adjust as needed.
# Never commit a real `.env` file.
# =========================================================================

# ---------- Application ----------
APP_ENV=dev
APP_NAME=nhpmbr
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000
APP_CORS_ORIGINS=http://localhost:3000

# ---------- API ----------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nhpmbr
POSTGRES_USER=nhpmbr
POSTGRES_PASSWORD=nhpmbr_dev_password_change_me
DATABASE_URL=postgresql+asyncpg://nhpmbr:nhpmbr_dev_password_change_me@postgres:5432/nhpmbr
SYNC_DATABASE_URL=postgresql+psycopg://nhpmbr:nhpmbr_dev_password_change_me@postgres:5432/nhpmbr

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- Object storage (MinIO / S3) ----------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=nhpmbr-dev
S3_ACCESS_KEY=nhpmbr_minio
S3_SECRET_KEY=nhpmbr_minio_dev_password_change_me
S3_USE_SSL=false
S3_PUBLIC_URL=http://localhost:9000

# ---------- Identity (Keycloak / OIDC) ----------
OIDC_ISSUER=http://keycloak:8080/realms/nhpmbr
OIDC_AUDIENCE=nhpmbr-api
OIDC_JWKS_URL=http://keycloak:8080/realms/nhpmbr/protocol/openid-connect/certs
OIDC_CLIENT_ID=nhpmbr-web
OIDC_CLIENT_SECRET=replace_me_in_keycloak_realm_export

# JWT (dev-only signing key for local fallback when Keycloak is offline)
JWT_DEV_SECRET=dev-only-secret-do-not-use-in-staging-or-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=604800

# ---------- Telemetry ----------
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=nhpmbr-api
SENTRY_DSN=

# ---------- Web app (Next.js) ----------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=NHPMBR
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_me_with_openssl_rand_hex_32
KEYCLOAK_CLIENT_ID=nhpmbr-web
KEYCLOAK_CLIENT_SECRET=replace_me_in_keycloak_realm_export
KEYCLOAK_ISSUER=http://localhost:8080/realms/nhpmbr
